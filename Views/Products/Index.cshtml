@model IEnumerable<GlassyStore.Models.Product>

@{
    ViewData["Title"] = "Shop";
}

<h2 class="mb-4">Eyewear Shop</h2>

<form asp-action="Index" method="get" class="mb-4">

    <div class="input-group">

        <input
            type="text"
            name="searchString"
            class="form-control"
            placeholder="Search frames or brands..." />

        <button class="btn btn-primary">

            Search

        </button>

    </div>

</form>

<div class="row">

@foreach(var item in Model)
{
    <div class="col-md-4 mb-4">

        <div class="card h-100 shadow">

            <img class="card-img-top"
                 src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/300x200?text=No+Image" : Url.Content($"~/images/{item.ImageUrl}"))"
                 style="height:250px; object-fit:cover;" />

            <div class="card-body">

                <h4>@item.Name</h4>

                <p>
                    <strong>Brand:</strong>
                    @item.Brand
                </p>

                <p>
                    <strong>Frame:</strong>
                    @item.FrameType
                </p>

                <p>
                    <strong>Material:</strong>
                    @item.Material
                </p>

                <h5 class="text-primary">
                    $@item.Price
                </h5>

                @if (item.StockQuantity > 5)
                {
                    <span class="badge bg-success">
                        In Stock
                    </span>
                }
                else if (item.StockQuantity > 0)
                {
                    <span class="badge bg-warning text-dark">
                        Only @item.StockQuantity left
                    </span>
                }
                else
                {
                    <span class="badge bg-danger">
                        Out of Stock
                    </span>
                }

            </div>

            <div class="card-footer text-center">

                <a asp-action="Details"
                   asp-route-productid="@item.ProductId"
                   class="btn btn-primary">

                    View Details

                </a>

            </div>

        </div>

    </div>
}

</div>
