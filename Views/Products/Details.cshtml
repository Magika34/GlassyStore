@model GlassyStore.Models.Product

@{
    ViewData["Title"] = "Product";
}

<div class="row">

    <div class="col-md-6">

        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://via.placeholder.com/500x350?text=No+Image" : Url.Content($"~/images/{Model.ImageUrl}"))"
             class="img-fluid rounded shadow" />

    </div>

    <div class="col-md-6">

        <h2>@Model.Name</h2>

        <hr />

        <p><strong>Brand:</strong> @Model.Brand</p>

        <p><strong>Frame Type:</strong> @Model.FrameType</p>

        <p><strong>Material:</strong> @Model.Material</p>

        <h3 class="text-success">
            $@Model.Price
        </h3>

        @if(Model.StockQuantity > 0)
        {
            <p class="text-success">
                In Stock (@Model.StockQuantity available)
            </p>

            <a asp-controller="Cart"
               asp-action="Add"
               asp-route-id="@Model.ProductId"
               class="btn btn-success">

                Add to Cart

            </a>
        }
        else
        {
            <p class="text-danger">
                Out of Stock
            </p>
        }

    </div>

</div>
