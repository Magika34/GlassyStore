@model GlassyStore.ViewModels.CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
}

<h2>Checkout</h2>

<form asp-action="Index">

    <div class="mb-3">
        <label>Frame</label>
        <select asp-for="ProductId"
                asp-items="ViewBag.Products"
                class="form-control">
        </select>
    </div>

    <div class="mb-3">
        <label>Lens Type</label>
        <select asp-for="LensOptionId"
                asp-items="ViewBag.Lenses"
                class="form-control">
        </select>
    </div>

    <div class="mb-3">
        <label>Sphere Left</label>
        <input asp-for="PrescriptionSphereLeft" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Sphere Right</label>
        <input asp-for="PrescriptionSphereRight" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Cylinder Left</label>
        <input asp-for="PrescriptionCylinderLeft" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Cylinder Right</label>
        <input asp-for="PrescriptionCylinderRight" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Pupillary Distance</label>
        <input asp-for="PupillaryDistance" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">
        Place Order
    </button>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}