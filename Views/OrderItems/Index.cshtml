@model IEnumerable<GlassyStore.Models.OrderItem>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.OrderId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Order)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Product)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LensOptionId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LensOption)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PrescriptionSphereLeft)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PrescriptionSphereRight)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PrescriptionCylinderLeft)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PrescriptionCylinderRight)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PupillaryDistance)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.OrderId)
            </td>
            <td>
                @Html.DisplayFor(model => item.Order)
            </td>
            <td>
                @Html.DisplayFor(model => item.ProductId)
            </td>
            <td>
                @Html.DisplayFor(model => item.Product)
            </td>
            <td>
                @Html.DisplayFor(model => item.LensOptionId)
            </td>
            <td>
                @Html.DisplayFor(model => item.LensOption)
            </td>
            <td>
                @Html.DisplayFor(model => item.PrescriptionSphereLeft)
            </td>
            <td>
                @Html.DisplayFor(model => item.PrescriptionSphereRight)
            </td>
            <td>
                @Html.DisplayFor(model => item.PrescriptionCylinderLeft)
            </td>
            <td>
                @Html.DisplayFor(model => item.PrescriptionCylinderRight)
            </td>
            <td>
                @Html.DisplayFor(model => item.PupillaryDistance)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.OrderItemId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.OrderItemId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.OrderItemId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
