@model IEnumerable<GlassyStore.Models.Order>

<h2>Administrator Dashboard</h2>

<table class="table">

n<thead>

n<tr>

n<th>Order</th>

n<th>Customer</th>

n<th>Status</th>

<th>Total</th>

<th></th>

</tr>

</thead>

<tbody>

@foreach(var order in Model)
{
<tr>

