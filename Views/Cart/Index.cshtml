@model IEnumerable<GlassyStore.Models.Product>

<h2>Shopping Cart</h2>

@if (!Model.Any())
{
    <p>Your cart is empty.</p>
}
else
{
    <table class="table">

        <tr>
            <th>Product</th>
            <th>Price</th>
            <th></th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Name</td>

                <td>@item.Price.ToString("C")</td>

                <td>

                    <a asp-action="Remove"
                       asp-route-id="@item.ProductId"
                       class="btn btn-danger btn-sm">
                        Remove
                    </a>

                </td>

            </tr>
        }

    </table>

    <a asp-controller="Checkout"
       asp-action="Index"
       asp-route-productId="@Model.First().ProductId"
       class="btn btn-primary">
        Checkout
    </a>
}
