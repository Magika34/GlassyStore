@page "/Admin/CheckUserRole"
@model GlassyStore.Pages.Admin.CheckUserRoleModel
@{
    ViewData["Title"] = "Check User Role";
}

<h1>Check User Role</h1>

<p>This page is protected to Administrator users only.</p>

<form method="get">
    <div class="form-group">
        <label for="email">Email</label>
        <input id="email" name="Email" class="form-control" value="@Model.Email" />
    </div>
    <button type="submit" class="btn btn-primary">Check</button>
</form>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="mt-3 alert alert-info">@Model.Message</div>
}

@if (Model.IsAdmin != null)
{
    <div>
        <strong>IsAdmin:</strong> @Model.IsAdmin
    </div>
}

<p class="mt-3">Example: <a href="/Admin/CheckUserRole?Email=admin@example.com">/Admin/CheckUserRole?Email=admin@example.com</a></p>
